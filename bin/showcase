#!/usr/bin/env ruby
# frozen_string_literal: true

# The Showcase Builder: generates the GitHub Pages site in docs/
# from the catalog itself - and it is, of course, an agentic plan.
# For every example, in parallel: parse the header, look up its
# persona and round in the perspectives tables, RUN it and capture
# the real output (every page shows a genuine run, not a paste).
# Then fan in: render one page per example, a searchable index, and
# a contribute page. A verify stage checks every page exists and
# every internal link resolves. The site that shows the examples is
# built by the framework the examples show.
#
#   AGENTIC_PATH=../agentic bundle exec ruby bin/showcase
#
# Writes docs/ (gitignored: CI rebuilds and deploys it on every merge;\n# run locally for preview).

require "bundler/setup"
require "agentic"
require "cgi"
require "json"
require "open3"
require "rbconfig"

Agentic.logger.level = :fatal

ROOT = File.expand_path("..", __dir__)
DOCS = File.join(ROOT, "docs")
EXPECTED_RED = %w[perf_diff.rb rule_prober.rb capability_evals.rb perf_history.rb eval_scorers.rb].freeze
SITE_TITLE = "Agentic Examples"
REPO_URL = "https://github.com/codenamev/agentic-examples"
BASE_URL = "https://www.codenamev.com/agentic-examples" # the account's Pages custom domain; github.io redirects here

CATEGORY_RULES = [
  ["Testing & Verification", /heckl|mutation|_spec|test|prover|drill|etude|doctest|golden|equival|eval|verify|refactor|shameless|dojo/],
  ["Reliability & Recovery", /retry|dead_letter|circuit|supervis|kill_switch|pool|runbook|deadline|timeout|saga|mirror|carrier|taxonomy|flaky|hostile|recovery|drain/],
  ["Data & Pipelines", /import|pipeline|scrub|refinery|darkroom|attachment|export|census|survey|document|typed_pipeline|roundtrip/],
  ["Scheduling & Concurrency", /queue|concurr|schedul|autoscal|rate_limit|bakery|firework|worker|thread|ractor|fiber|stampede|burst|slot|kanban|traffic|server|process/],
  ["Observability & Ops", /journal|profil|trace|metric|observ|telemetry|cinema|vm_eye|perf|latency|checkin|config|deploy|canary|recorder|hill|gantt|weekly|standup|drip|ledger|spend|invoice|shadow/],
  ["Developer Experience", /scaffold|generat|script|did_you_mean|404|doctor|loader|autoload|lint|cop|style|suggest|screencast|onboarding|trail|kata|index|coverage|api|contract|rbs|types?_|seance|lockfile|resolver|deprecat/],
  ["Plans & Graphs", /graph|plan_|diagram|merge|diff|invariant|shapes|tour|structural|critic|flog|roundtrip|borrow|lightning/],
  ["Fun & Strange", /mandala|band|wat_|poet|bard|renga|pinball|demoscene|nothing|game|corpse|haiku|duck|bottles|museum|stack_vm/]
].freeze

def category_for(name, text)
  CATEGORY_RULES.each { |cat, rx| return cat if name.match?(rx) || text.downcase.match?(rx) }
  "Patterns"
end

# --- gather the cast/round metadata from the perspectives tables ---------------------
def perspective_rows
  rows = {}
  round = nil
  File.readlines(File.join(ROOT, "perspectives/README.md"), encoding: "UTF-8").each do |line|
    round = Regexp.last_match(1).strip if line =~ /^## (Round \d+[^|]*)$/
    next unless line =~ /\|\s*\d+\s*\|\s*([^|]+?)\s*\|\s*([^|]+?)\s*\|\s*`examples\/([\w.]+)`\s*\|\s*\[[^\]]+\]\(([^)]+)\)/
    rows[Regexp.last_match(3)] ||= {persona: Regexp.last_match(1), blurb: Regexp.last_match(2),
                                    round: round.to_s.sub(/ —.*/, ""), notes: Regexp.last_match(4)}
  end
  rows
end

# --- tiny ruby colorizer (escaped input; best-effort, no dependencies) ---------------
KEYWORDS = %w[def end do if else elsif unless case when then while until return next break
  module class begin rescue ensure raise yield lambda require require_relative true false nil self].freeze
def highlight(escaped_line)
  return %(<span class="c">#{escaped_line}</span>) if escaped_line.lstrip.start_with?("#")
  escaped_line
    .gsub(/(&quot;.*?&quot;)/, '<span class="s">\1</span>')
    .gsub(/(?<![\w&])(:\w+)/, '<span class="y">\1</span>')
    .gsub(/\b(#{KEYWORDS.join("|")})\b/, '<span class="k">\1</span>')
    .gsub(/ (#.*)$/) { " <span class=\"c\">#{Regexp.last_match(1)}</span>" }
end

def page(title, body, depth: 0, description: "Runnable, self-verifying examples of plan-and-execute Ruby.", path: "")
  prefix = "../" * depth
  <<~HTML
    <!doctype html>
    <html lang="en"><head>
    <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
    <title>#{CGI.escapeHTML(title)}</title>
    <meta property="og:title" content="#{CGI.escapeHTML(title)}">
    <meta property="og:description" content="#{CGI.escapeHTML(description[0, 200])}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="#{BASE_URL}/#{path}">
    <meta property="og:image" content="#{BASE_URL}/og.png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="description" content="#{CGI.escapeHTML(description[0, 200])}">
    <link rel="stylesheet" href="#{prefix}style.css">
    </head><body>
    <header><a class="brand" href="#{prefix}index.html">agentic examples</a>
    <nav><a href="#{prefix}contribute.html">contribute</a>
    <a href="#{REPO_URL}">github</a></nav></header>
    <main>#{body}</main>
    <footer>every page shows a real captured run · site generated by <code>bin/showcase</code>, an agentic plan · MIT</footer>
    </body></html>
  HTML
end

STYLE = <<~CSS
  :root { --bg:#0d1117; --panel:#161b22; --ink:#e6edf3; --dim:#8b949e; --accent:#ff6b6b; --green:#7ee787; --border:#30363d; }
  @media (prefers-color-scheme: light) { :root { --bg:#fafafa; --panel:#fff; --ink:#1f2328; --dim:#57606a; --accent:#c9302c; --green:#1a7f37; --border:#d0d7de; } }
  * { box-sizing:border-box; } body { margin:0; background:var(--bg); color:var(--ink); font:16px/1.6 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
  header { display:flex; justify-content:space-between; align-items:baseline; padding:14px 24px; border-bottom:1px solid var(--border); }
  .brand { color:var(--accent); text-decoration:none; font-weight:700; } nav a { color:var(--dim); margin-left:16px; text-decoration:none; } nav a:hover { color:var(--ink); }
  main { max-width:980px; margin:0 auto; padding:24px; } footer { text-align:center; color:var(--dim); font-size:12px; padding:24px; border-top:1px solid var(--border); margin-top:32px; }
  h1 { font-size:26px; margin:8px 0 4px; } .sub { color:var(--dim); margin:0 0 20px; }
  .controls { display:flex; gap:10px; flex-wrap:wrap; margin:16px 0; }
  #q { flex:1; min-width:220px; background:var(--panel); color:var(--ink); border:1px solid var(--border); border-radius:8px; padding:9px 12px; font:inherit; }
  .chip { background:var(--panel); border:1px solid var(--border); border-radius:999px; padding:5px 12px; font-size:12.5px; color:var(--dim); cursor:pointer; user-select:none; }
  .chip.on { color:var(--ink); border-color:var(--accent); }
  .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:12px; }
  .card { background:var(--panel); border:1px solid var(--border); border-radius:10px; padding:14px 16px; text-decoration:none; color:inherit; display:block; }
  .card:hover { border-color:var(--accent); } .card h3 { margin:0 0 6px; font-size:15.5px; color:var(--accent); }
  .card p { margin:0 0 10px; font-size:13px; color:var(--dim); max-height:4.9em; overflow:hidden; }
  .badges { display:flex; gap:6px; flex-wrap:wrap; } .badge { font-size:11px; border:1px solid var(--border); border-radius:5px; padding:1px 7px; color:var(--dim); }
  .badge.cat { color:var(--green); border-color:var(--green); }
  pre { background:var(--panel); border:1px solid var(--border); border-radius:10px; padding:16px; overflow-x:auto; font-size:13px; line-height:1.5; }
  pre.output { border-left:3px solid var(--green); } pre.src { border-left:3px solid var(--accent); }
  .c { color:var(--dim); font-style:italic; } .s { color:var(--green); } .y { color:#d2a8ff; } .k { color:var(--accent); }
  .meta a { color:var(--green); } .count { color:var(--dim); font-size:13px; }
  .runline { background:var(--panel); border:1px dashed var(--border); border-radius:8px; padding:8px 12px; display:inline-block; margin:8px 0; }
  section.doc h2 { margin-top:28px; } code { color:var(--green); }
CSS

# --- the og:image: the frozen mandala\'s own pattern, as pixels, no image libs ------
require "zlib"
def png_chunk(type, data)
  [data.bytesize].pack("N") + type + data + [Zlib.crc32(type + data)].pack("N")
end

def write_og_image(path)
  w = 1200
  h = 630
  bg = [13, 17, 23]
  palette = {1 => [139, 148, 158], 2 => [210, 168, 255], 3 => [126, 231, 135], 4 => [255, 107, 107]}
  radii = 11
  cell = 27
  size = radii * 2 + 1
  ox = (w - size * cell) / 2
  oy = (h - size * cell) / 2
  # the same math as examples/frozen_mandala.rb, seed 42
  glyph_at = ->(gx, gy) {
    dx = gx - radii
    dy = gy - radii
    r = Math.sqrt(dx * dx + dy * dy).round
    return 0 if r >= radii
    angle = (Math.atan2(dy, dx) + Math::PI) / (2 * Math::PI)
    a = [(angle * 8 % 1 * 12).floor, 11].min
    v = (r * r + a * (a + 3) + 42 * 7) % 9
    (v < 4) ? 1 + ((r + a + 42) % 4) : 0
  }
  rows = h.times.map { |y|
    "\0" + w.times.map { |x|
      gx = (x - ox) / cell
      gy = (y - oy) / cell
      inside = gx.between?(0, size - 1) && gy.between?(0, size - 1)
      color = inside ? (palette[glyph_at.call(gx, gy)] || bg) : bg
      color.pack("C3")
    }.join
  }.join
  ihdr = png_chunk("IHDR", [w, h, 8, 2, 0, 0, 0].pack("NNC5"))
  idat = png_chunk("IDAT", Zlib::Deflate.deflate(rows))
  File.binwrite(path, "\x89PNG\r\n\x1a\n".b + ihdr + idat + png_chunk("IEND", ""))
end

puts "SHOWCASE BUILDER (the site about the examples, built by an example of the framework)"
cast = perspective_rows
files = Dir[File.join(ROOT, "examples", "*.rb")].sort - [File.join(ROOT, "examples", "examples_index.rb")]
puts "  #{files.size} examples to parse, run, and render (#{cast.size} with field notes)"

orchestrator = Agentic::PlanOrchestrator.new(concurrency_limit: 8)

survey_tasks = files.map do |path|
  parse = Agentic::Task.new(description: "parse #{File.basename(path)}", agent_spec: {"name" => "librarian", "instructions" => "parse"}, payload: path)
  capture = Agentic::Task.new(description: "run #{File.basename(path)}", agent_spec: {"name" => "projectionist", "instructions" => "run"})
  orchestrator.add_task(parse, agent: ->(t) {
    lines = File.readlines(t.payload, encoding: "UTF-8").reject { |l| l.start_with?("# frozen_string_literal") }
    header = lines.drop_while { |l| !l.start_with?("#") }.take_while { |l| l.start_with?("#") }
    prose = header.map { |l| l.sub(/\A#\s?/, "").rstrip }
    name = File.basename(t.payload)
    para = prose.take_while { |l| !l.empty? }
    title = para.first.to_s[/\A([^:.]{3,60})[:.]/, 1] || name.sub(".rb", "").tr("_", " ")
    {name: name, title: title.strip, description: para.join(" ").squeeze(" "),
     source: File.read(t.payload, encoding: "UTF-8"), info: cast[name]}
  })
  orchestrator.add_task(capture, [parse], agent: ->(t) {
    meta = t.previous_output
    out, _err, status = Open3.capture3({"BUNDLE_GEMFILE" => File.join(ROOT, "Gemfile")},
      "timeout", "90", RbConfig.ruby, "-rbundler/setup", File.join(ROOT, "examples", meta[:name]))
    out = out.force_encoding(Encoding::UTF_8).scrub # child pipes arrive US-ASCII in locale-less containers
    expected = EXPECTED_RED.include?(meta[:name]) ? 1 : 0
    meta.merge(output: out, exit: status.exitstatus, exit_ok: status.exitstatus == expected,
      category: category_for(meta[:name], meta[:title] + " " + meta[:description]))
  })
  capture
end

render = Agentic::Task.new(description: "render site", agent_spec: {"name" => "typesetter", "instructions" => "render"})
orchestrator.add_task(render, survey_tasks, agent: ->(t) {
  entries = survey_tasks.map { |st| t.output_of(st) }.sort_by { |e| e[:name] }
  Dir.mkdir(DOCS) unless Dir.exist?(DOCS)
  Dir.mkdir(File.join(DOCS, "examples")) unless Dir.exist?(File.join(DOCS, "examples"))
  File.write(File.join(DOCS, ".nojekyll"), "")
  File.write(File.join(DOCS, "style.css"), STYLE)
  write_og_image(File.join(DOCS, "og.png"))

  entries.each do |e|
    slug = e[:name].sub(".rb", "")
    info = e[:info] || {}
    notes_link = info[:notes] ? %(<a href="#{REPO_URL}/blob/main/perspectives/#{info[:notes]}">field notes</a> · ) : ""
    src_html = e[:source].lines.map { |l| highlight(CGI.escapeHTML(l.rstrip)) }.join("\n")
    out_lines = e[:output].lines
    shown = out_lines.first(120).map { |l| CGI.escapeHTML(l.rstrip) }.join("\n")
    shown += "\n… (#{out_lines.size - 120} more lines)" if out_lines.size > 120
    body = <<~HTML
      <h1>#{CGI.escapeHTML(e[:title])}</h1>
      <p class="sub">#{CGI.escapeHTML(e[:description][0, 480])}</p>
      <div class="badges">
        <span class="badge cat">#{e[:category]}</span>
        #{info[:round] ? %(<span class="badge">#{CGI.escapeHTML(info[:round])}</span>) : ""}
        #{info[:persona] ? %(<span class="badge">#{CGI.escapeHTML(info[:persona])}</span>) : ""}
        <span class="badge">exit #{e[:exit]}#{EXPECTED_RED.include?(e[:name]) ? " (red by design)" : ""}</span>
      </div>
      <p class="meta">#{notes_link}<a href="#{REPO_URL}/blob/main/examples/#{e[:name]}">source on github</a></p>
      <div class="runline">bundle exec ruby examples/#{e[:name]}</div>
      <h2>a real captured run</h2>
      <pre class="output">#{shown}</pre>
      <h2>source</h2>
      <pre class="src">#{src_html}</pre>
    HTML
    File.write(File.join(DOCS, "examples", "#{slug}.html"),
      page("#{e[:title]} · #{SITE_TITLE}", body, depth: 1, description: e[:description], path: "examples/#{slug}.html"))
  end

  catalog = entries.map { |e|
    {slug: e[:name].sub(".rb", ""), title: e[:title], desc: e[:description][0, 220],
     cat: e[:category], round: e.dig(:info, :round).to_s, persona: e.dig(:info, :persona).to_s}
  }
  cats = catalog.map { |c| c[:cat] }.tally.sort_by { |_, n| -n }
  cards = catalog.map { |c|
    <<~HTML
      <a class="card" data-cat="#{c[:cat]}" data-hay="#{CGI.escapeHTML([c[:slug], c[:title], c[:desc], c[:persona], c[:round]].join(" ").downcase)}" href="examples/#{c[:slug]}.html">
      <h3>#{CGI.escapeHTML(c[:title])}</h3><p>#{CGI.escapeHTML(c[:desc])}</p>
      <div class="badges"><span class="badge cat">#{c[:cat]}</span>#{c[:persona].empty? ? "" : %(<span class="badge">#{CGI.escapeHTML(c[:persona])}</span>)}</div></a>
    HTML
  }.join
  index_body = <<~HTML
    <h1>#{entries.size} runnable examples of plan-and-execute Ruby</h1>
    <p class="sub">Every example runs offline, checks itself, and exits honestly - built across twenty rounds
    of persona-driven development on <a href="https://github.com/codenamev/agentic">agentic</a>.
    Each page shows a real captured run. <a href="contribute.html">Point your agent here to add one.</a></p>
    <div class="controls"><input id="q" type="search" placeholder="search #{entries.size} examples - try 'retry', 'queue', 'mandala'...">
    <span class="chip on" data-cat="">all</span>#{cats.map { |c, n| %(<span class="chip" data-cat="#{c}">#{c} · #{n}</span>) }.join}</div>
    <p class="count"><span id="n">#{entries.size}</span> shown</p>
    <div class="grid" id="grid">#{cards}</div>
    <script>
    const q=document.getElementById('q'),cards=[...document.querySelectorAll('.card')],chips=[...document.querySelectorAll('.chip')];
    let cat='';
    function apply(){const t=q.value.toLowerCase();let n=0;
      cards.forEach(c=>{const ok=(!cat||c.dataset.cat===cat)&&(!t||c.dataset.hay.includes(t));c.style.display=ok?'':'none';if(ok)n++;});
      document.getElementById('n').textContent=n;}
    q.addEventListener('input',apply);
    chips.forEach(ch=>ch.addEventListener('click',()=>{chips.forEach(x=>x.classList.remove('on'));ch.classList.add('on');cat=ch.dataset.cat;apply();}));
    </script>
  HTML
  File.write(File.join(DOCS, "index.html"), page(SITE_TITLE, index_body, path: "index.html"))

  contribute_body = <<~HTML
        <h1>Contribute an example (or just an idea)</h1>
        <p class="sub">This catalog is built to be extended by agents. Point yours at the repo and hand it the loop below -
        or file an idea and let someone else's agent build it.</p>
        <section class="doc">
        <h2>The quality bar</h2>
        <pre>- runs OFFLINE (no network, no API keys) in under 60 seconds
    - demonstrates ONE idea, applied to a problem outside the framework itself
    - checks itself: a referee computes a verdict and the script exits 0 or 1 honestly
    - header comment: what it shows, why it matters, and the exact run line
    - ~120 lines; standardrb clean; deterministic exit across runs</pre>
        <h2>The loop for an agent</h2>
        <pre>git clone #{REPO_URL} && cd agentic-examples
    bundle install                        # agentic comes from git; AGENTIC_PATH=... overrides
    bin/contribute new my_example        # scaffold with the house conventions
    $EDITOR examples/my_example.rb       # build the idea
    bin/contribute check my_example      # the acceptance gates - iterate until green
    bundle exec ruby examples/examples_index.rb
    # open a PR titled: example: my_example (one example per PR; don't touch docs/)</pre>
        <p>The full protocol lives in <a href="#{REPO_URL}/blob/main/AGENTS.md">AGENTS.md</a> -
        written for agents, humans welcome. CI runs the same <code>bin/contribute check</code> your agent ran locally.</p>
        <h2>Idea only?</h2>
        <p><a href="#{REPO_URL}/issues/new?template=example-idea.yml">Open an example-idea issue</a>: the problem,
        why a plan fits it, and what the referee would assert. Ideas are the round seeds.</p>
        </section>
  HTML
  File.write(File.join(DOCS, "contribute.html"),
    page("Contribute · #{SITE_TITLE}", contribute_body, description: "Point your agent at this repo to add an example - scaffold, pass the gates, open a PR.", path: "contribute.html"))
  entries
})

verify = Agentic::Task.new(description: "verify site", agent_spec: {"name" => "inspector", "instructions" => "verify"})
orchestrator.add_task(verify, [render], agent: ->(t) {
  entries = t.previous_output
  problems = []
  entries.each do |e|
    slug = e[:name].sub(".rb", "")
    problems << "missing page for #{e[:name]}" unless File.exist?(File.join(DOCS, "examples", "#{slug}.html"))
    unless e[:exit_ok]
      flagged = e[:output].lines.grep(/!!|FAIL|REFUSED|Error/i).first(4)
      quoted = (flagged + e[:output].lines.last(2)).map(&:strip).uniq.join(" | ")
      problems << "#{e[:name]} exited #{e[:exit]} unexpectedly: #{quoted[0, 400]}"
    end
    problems << "#{e[:name]} captured no output" if e[:output].strip.empty?
  end
  index = File.read(File.join(DOCS, "index.html"), encoding: "UTF-8")
  index.scan(/href="(examples\/[^"]+)"/).flatten.uniq.each do |link|
    problems << "dead link #{link}" unless File.exist?(File.join(DOCS, link))
  end
  problems
})

result = orchestrator.execute_plan
problems = result.task_result(verify.id).output
pages = Dir[File.join(DOCS, "**", "*.html")].size
puts "  rendered #{pages} pages into docs/ (#{files.size} example pages + index + contribute)"
if problems.empty?
  puts "  verify: every page present, every run captured, every internal link resolves."
else
  puts "  verify FAILED:"
  problems.first(10).each { |p| puts "    - #{p}" }
end
exit(problems.empty? ? 0 : 1)
